<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.student_course_registration.ProfileController">

    <style>
        .root {
        -fx-background-color: #f5f5ff;
        }

        .header {
        -fx-background-color: #2d1f4d;
        -fx-padding: 15;
        }

        .title-text {
        -fx-font-size: 24px;
        -fx-text-fill: white;
        -fx-font-weight: bold;
        }

        .form-container {
        -fx-background-color: white;
        -fx-background-radius: 10;
        -fx-padding: 20;
        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);
        }

        .field-label {
        -fx-font-size: 14px;
        -fx-text-fill: #666;
        }

        .text-field {
        -fx-pref-width: 300;
        -fx-background-radius: 5;
        }

        .button {
        -fx-background-radius: 20;
        -fx-padding: 8 20;
        -fx-font-weight: bold;
        -fx-cursor: hand;
        }

        .save-button {
        -fx-background-color: #4CAF50;
        -fx-text-fill: white;
        }

        .back-button {
        -fx-background-color: #f44336;
        -fx-text-fill: white;
        }
    </style>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Header -->
    <HBox styleClass="header">
        <Label text="Student Profile" styleClass="title-text"/>
    </HBox>

    <!-- Profile Form -->
    <VBox styleClass="form-container" spacing="15">
        <GridPane vgap="15" hgap="10">
            <Label text="Name:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Email:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Program:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="programField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Semester:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="semesterField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        </GridPane>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="Save Changes" onAction="#handleSave" styleClass="button, save-button"/>
        <Button text="Back to Dashboard" onAction="#handleBack" styleClass="button, back-button"/>
    </HBox>

    <Label fx:id="messageLabel"/>
</VBox>